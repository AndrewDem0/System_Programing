<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:DynamicTypeIdentification" 
        x:Class="DynamicTypeIdentification.MainWindow"
        Title="Type Inspector" Width="600" Height="450">
    
    <Grid RowDefinitions="Auto,*">
        <Button Name="BtnReflect" Click="BtnReflect_Click" Content="Інспектувати об'єкт" Grid.Row="0" Margin="10"/>
        
        <TreeView Name="PropertiesTreeView" Grid.Row="1" Margin="10">
            <TreeView.ItemTemplate>
                <TreeDataTemplate DataType="{x:Type local:ReflectionNode}" ItemsSource="{Binding Children}">
                    <TextBlock Text="{Binding Header}" />
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</Window>